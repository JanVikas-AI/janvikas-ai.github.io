rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all: Default to deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Citizen Signals: Allow public read and write access for dynamic intake & synchronization
    match /citizenSignals/{id} {
      allow read, write: if true;
    }

    // AI Analysis: Allow public read and write access for backend pipeline storage & client view
    match /aiAnalysis/{id} {
      allow read, write: if true;
    }

    // Evidence Clusters: Allow public read and write access for clustering services & maps
    match /evidenceClusters/{id} {
      allow read, write: if true;
    }

    // Development Projects: Allow public read and write access for prioritized administrative analytics
    match /developmentProjects/{id} {
      allow read, write: if true;
    }

    // Executive Briefs: Allow public read and write access for master constituency summaries
    match /executiveBriefs/{id} {
      allow read, write: if true;
    }

    // Governance Copilot: Allow public read and write access for chat session historical storage
    match /governanceCopilot/{id} {
      allow read, write: if true;
    }
  }
}
